# ============================================
# Large Binary Assets — NOT tracked via Git!
# ============================================
# These large files are hosted on a shared cloud drive/network disk.
# See README.md (📥 大文件下载与放置指南) for download and placement instructions.

# Astronaut 3D assets (44MB GLB + textures)
astronaut/

# Moon 3D assets (1.8GB BLEND + textures)
moon/

# Main textures directory (moved to Assets/Models/... but keep for reference)
textures/

# My project/Assets/Models/ - large 3D files only (but keep .meta files!)
# Note: .meta files are critical - DO NOT ignore them!
My project/Assets/Models/astronaut/source/*.glb
My project/Assets/Models/astronaut/source/*.gltf
My project/Assets/Models/astronaut/source/*.fbx
My project/Assets/Models/astronaut/textures/*.png
My project/Assets/Models/astronaut/textures/*.jpg
My project/Assets/Models/astronaut/textures/*.tga

My project/Assets/Models/moon/*.blend
My project/Assets/Models/moon/textures/*.png
My project/Assets/Models/moon/textures/*.jpg
My project/Assets/Models/moon/textures/*.tga

